# Clothing try-on backend: "fal" (hosted Kling) or "runpod" (self-hosted CatVTON-FLUX)
VTON_PROVIDER=fal

# fal.ai API key — get one at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-key-here

# RunPod serverless (generative SOTA) — see runpod/*/README.md
# RUNPOD_API_KEY=your-runpod-key
# RUNPOD_ENDPOINT_ID=clothing-catvton-flux-endpoint
# RUNPOD_CATEGORY=upper                      # upper | lower | overall
# RUNPOD_MAKEUP_ENDPOINT_ID=stable-makeup-endpoint

# Optional overrides
# FAL_MODEL=fal-ai/kling/v1-5/kolors-virtual-try-on
# CORS_ORIGINS=["http://localhost:5173"]
